VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_ODPT_API_KEY=your-odpt-api-key

# Server-side only — required for student/teacher account create (local dev + Vercel):
# Supabase → Settings → API → service_role (never commit or expose as VITE_)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Web Push — for risk-student notifications (generate with: npx web-push generate-vapid-keys)
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@example.com
